{
  "name": "open-memo",
  "version": "0.2.1",
  "description": "Open-source push-to-talk dictation for macOS",
  "homepage": "https://github.com/oliverbhull/open-memo",
  "main": "dist/main.cjs",
  "preload": "dist/preload.cjs",
  "type": "module",
  "scripts": {
    "dev": "npm run build:backends && npm run build:ts && concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:preload\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "esbuild electron/main/index.ts --platform=node --bundle --external:electron --outfile=dist/main.cjs --format=cjs --watch",
    "dev:preload": "esbuild electron/preload/index.ts --platform=node --bundle --external:electron --outfile=dist/preload.cjs --format=cjs --watch",
    "build:ts": "npm run build:main && npm run build:preload && npm run build:overlay-preload",
    "build:main": "esbuild electron/main/index.ts --platform=node --bundle --external:electron --outfile=dist/main.cjs --format=cjs",
    "build:preload": "esbuild electron/preload/index.ts --platform=node --bundle --external:electron --outfile=dist/preload.cjs --format=cjs",
    "build:overlay-preload": "esbuild electron/preload/overlay.ts --platform=node --bundle --external:electron --outfile=dist/overlay-preload.cjs --format=cjs",
    "build:renderer": "vite build --config vite.config.ts",
    "build:stt:release": "bash scripts/shell/build-stt.sh",
    "build:nemotron": "bash scripts/shell/build-nemotron.sh",
    "verify:nemotron": "bash scripts/shell/verify-nemotron-bundle.sh",
    "build:backends": "npm run build:stt:release && npm run build:nemotron",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.json",
    "test": "esbuild tests/*.test.ts --bundle --platform=node --format=esm --outdir=.build/tests && node --test .build/tests/*.test.js",
    "check": "npm run typecheck && npm test",
    "build:app": "npm run check && npm run build:backends && npm run build:ts && npm run build:renderer",
    "build:dir": "npm run build:app && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir",
    "dist:mac": "npm run build:app && electron-builder --mac --publish=never",
    "release:mac": "npm run dist:mac",
    "build": "npm run dist:mac",
    "start": "npm run build:backends && npm run build:ts && electron .",
    "export-memos": "npm run build:main && npm run build:renderer && MEMO_EXPORT=1 electron ."
  },
  "keywords": [
    "nemotron",
    "speech-to-text",
    "dictation",
    "push-to-talk",
    "electron",
    "transcription"
  ],
  "author": "Oliver Hull",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "productName": "Memo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliverbhull/open-memo.git"
  },
  "bugs": {
    "url": "https://github.com/oliverbhull/open-memo/issues"
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.2",
    "vite": "^8.1.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.memo.desktop",
    "productName": "Memo",
    "artifactName": "Open-Memo-${version}-${arch}.${ext}",
    "asar": true,
    "nodeGypRebuild": false,
    "npmRebuild": true,
    "mac": {
      "icon": "assets/app-icons/app-icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "config/entitlements.mac.plist",
      "entitlementsInherit": "config/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Memo needs microphone access to record audio for transcription.",
        "NSBluetoothAlwaysUsageDescription": "Memo uses Bluetooth to connect to Memo devices."
      },
      "notarize": true
    },
    "dmg": {
      "icon": "assets/app-icons/app-icon.icns",
      "background": "assets/dmg-background.png",
      "contents": [
        {
          "x": 180,
          "y": 220,
          "type": "file"
        },
        {
          "x": 480,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 660,
        "height": 450
      }
    },
    "files": [
      "dist/main.cjs",
      "dist/preload.cjs",
      "dist/overlay-preload.cjs",
      "dist-react/**",
      "assets/app-icons/app-icon.icns",
      "assets/dmg-background.png",
      "assets/icon-16.png",
      "assets/icon-16@2x.png",
      "assets/icon_green-16.png",
      "assets/icon_green-16@2x.png",
      "assets/icon_red-16.png",
      "assets/icon_blue-16.png",
      "assets/icon_blue-16@2x.png",
      "electron/renderer/overlay.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".build/stt/",
        "to": "sttbin",
        "filter": [
          "memo-stt"
        ]
      },
      {
        "from": ".build/nemotron/",
        "to": "nemotron"
      }
    ],
    "afterPack": "scripts/afterPack.cjs",
    "publish": [
      {
        "provider": "github",
        "owner": "oliverbhull",
        "repo": "open-memo"
      }
    ]
  }
}
